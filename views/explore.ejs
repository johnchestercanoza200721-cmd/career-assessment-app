<!DOCTYPE html>
<html>
<head>
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Explore Courses</title>
    
    <style>
        * {
            -webkit-tap-highlight-color: transparent;
            -webkit-tap-highlight-color: rgba(0, 0, 0, 0);
        }

        :root {
            --main-font: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
            --bg-color: #f0f2f5;
            --card-bg: #ffffff;
            --text-main: #2c3e50;
            --text-muted: #5f6368;
            --nav-bg-rgb: 255, 255, 255;
            --nav-text: #2c3e50;
            --border-color: #dadce0;
            --shadow: rgba(0,0,0,0.1);
            --accent-blue: #1a73e8;
        }

        body.dark-mode {
            --bg-color: #121212;
            --card-bg: #1e1e1e;
            --text-main: #e8eaed;
            --text-muted: #9aa0a6;
            --nav-bg-rgb: 30, 30, 30;
            --nav-text: #e8eaed;
            --border-color: #3c4043;
            --shadow: rgba(0,0,0,0.4);
        }

        body.warm-mode::after {
            content: "";
            position: fixed;
            top: 0; left: 0;
            width: 100vw; height: 100vh;
            background: rgba(255, 145, 0, 0.15);
            pointer-events: none;
            z-index: 9999;
            mix-blend-mode: multiply;
        }

        html, body {
            margin: 0;
            padding: 0;
            width: 100%;
            overflow-x: hidden;
            font-family: var(--main-font);
            background-color: var(--bg-color);
            color: var(--text-main);
            -webkit-font-smoothing: antialiased;
            -moz-osx-font-smoothing: grayscale;
            transition: background-color 0.3s ease, color 0.3s ease;
        }

        body {
            padding-top: 90px;
            padding-bottom: 50px;
        }

        /* --- NAVBAR --- */
        .navbar {
            position: fixed;
            top: 0;
            left: 0;
            right: 0;
            width: 100%;
            height: 70px;
            
            background-color: rgba(var(--nav-bg-rgb), 0.25);
            backdrop-filter: blur(10px);
            -webkit-backdrop-filter: blur(10px);
            
            display: flex;
            justify-content: center;
            align-items: center;
            
            z-index: 2000;
            box-shadow: 0 2px 10px var(--shadow);
            border-bottom: 1px solid var(--border-color);
            
            transform: translateZ(0);
            -webkit-transform: translateZ(0);
            margin: 0;
            padding: 0;
        }

        .nav-container {
            display: grid;
            grid-template-columns: 1fr auto 1fr;
            align-items: center;
            width: 95%;
            max-width: 1200px;
            margin: 0 auto;
        }

        .nav-logo {
            font-size: 1.4rem;
            font-weight: 800;
            text-decoration: none;
            color: var(--nav-text);
            letter-spacing: -0.5px;
            transition: opacity 0.2s ease;
        }

        .nav-logo:hover { opacity: 0.8; }

        .nav-logo span {
            background: linear-gradient(135deg, #1a73e8, #00d4ff);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            font-weight: 900;
        }

        .nav-link {
            text-decoration: none;
            color: var(--text-muted);
            font-weight: 600;
            font-size: 0.9rem;
            transition: all 0.2s ease;
        }

        .nav-link:hover {
            color: var(--accent-blue);
        }

        /* --- HOME ICON --- */
        .home-icon {
            display: flex;
            align-items: center;
            justify-content: center;
            width: 40px;
            height: 40px;
            border-radius: 50%;
            color: var(--nav-text);
            transition: all 0.3s ease;
            cursor: pointer;
            text-decoration: none;
            border: none;
            background: transparent;
            padding: 0;
        }

        .home-icon:hover {
            background: rgba(0, 0, 0, 0.08);
            transform: scale(1.1);
        }

        .home-icon svg {
            transition: all 0.3s ease;
        }

        .home-icon:hover svg {
            stroke: var(--accent-blue);
        }

        .light-mode .home-icon:hover {
            background: rgba(0, 0, 0, 0.08);
        }

        /* --- MOBILE DRAWER --- */
        .mobile-drawer {
            position: fixed;
            top: 15px;
            bottom: 15px;
            right: -110%;
            width: 290px;
            
            background: rgba(var(--nav-bg-rgb), 0.5) !important;
            backdrop-filter: blur(15px) saturate(160%);
            -webkit-backdrop-filter: blur(25px) saturate(160%);
            
            z-index: 3000;
            padding: 70px 25px 40px;
            border-radius: 24px;
            border: 1px solid rgba(255, 255, 255, 0.12);
            
            visibility: hidden;
            pointer-events: none;
            
            transition: all 0.5s cubic-bezier(0.16, 1, 0.3, 1);
        }

        .mobile-drawer.active {
            right: 15px;
            visibility: visible;
            pointer-events: auto;
            box-shadow: -15px 15px 50px rgba(0,0,0,0.1);
        }

        .mobile-drawer h3 {
            font-size: 2rem;
            font-weight: 800;
            color: var(--text-main);
            margin-bottom: 35px;
            padding-bottom: 15px;
            text-align: left;
            letter-spacing: -0.5px;
        }

        .mobile-drawer h3 span {
            color: var(--accent-blue);
        }

        .drawer-links {
            list-style: none !important;
            padding: 0 !important;
            margin: 0;
        }

        .drawer-links li {
            list-style: none !important;
            margin-bottom: 12px;
        }

        .drawer-links a {
            text-decoration: none;
            color: var(--text-main);
            font-size: 1rem;
            font-weight: 600;
            display: block;
            padding: 14px 20px;
            border-radius: 18px;
            
            background: hsla(0, 0%, 40%, 0.05);
            border: 1px solid hsla(0, 0%, 40%, 0.5);
            transition: all 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
        }

        .drawer-links a:hover {
            background: var(--accent-blue);
            color: white !important;
            transform: translateX(8px) scale(1.02);
            box-shadow: 0 8px 20px rgba(26, 115, 232, 0.3);
            border-color: rgba(255, 255, 255, 0.2);
        }

        .close-drawer {
            position: absolute;
            top: 20px;
            right: 20px;
            width: 36px;
            height: 36px;
            background: #66666680;
            border-radius: 50%;
            border: 1px solid rgba(255, 255, 255, 0.1);
            cursor: pointer;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 0;
            transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
            z-index: 10;
        }

        .close-drawer::before,
        .close-drawer::after {
            content: '';
            position: absolute;
            width: 16px;
            height: 2px;
            background-color: var(--text-muted);
            border-radius: 2px;
            transition: background-color 0.3s ease;
        }

        .close-drawer::before { transform: rotate(45deg); }
        .close-drawer::after { transform: rotate(-45deg); }

        .close-drawer:hover {
            background: rgba(255, 255, 255, 0.15);
            transform: rotate(135deg);
        }

        .close-drawer:hover::before,
        .close-drawer:hover::after {
            background-color: var(--text-main);
        }

        .light-mode .mobile-drawer {
            background: rgba(255, 255, 255, 0.95) !important;
            border: 1px solid rgba(0, 0, 0, 0.08);
            box-shadow: -10px 10px 40px rgba(0, 0, 0, 0.15);
        }

        .light-mode .mobile-drawer h3 {
            color: #000;
            border-bottom-color: rgba(0, 0, 0, 0.05);
        }

        .light-mode .drawer-links a {
            background: rgba(0, 0, 0, 0.05);
            border: 1px solid rgba(0, 0, 0, 0.05);
            color: #222;
        }

        .light-mode .drawer-links a:hover {
            background: var(--accent-blue);
            color: white !important;
        }

        .light-mode .close-drawer {
            background: rgba(0, 0, 0, 0.05);
            border-color: rgba(0, 0, 0, 0.1);
        }

        .drawer-overlay {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            
            background: rgba(0, 0, 0, 0.25);
            
            backdrop-filter: blur(8px);
            -webkit-backdrop-filter: blur(8px);
            
            display: none;
            z-index: 2500;
            
            animation: fadeIn 0.3s ease;
        }

        .drawer-overlay.active {
            display: block;
        }

        .drawer-content {
            position: relative;
        }

        .nav-controls {
            display: flex;
            gap: 15px;
            align-items: center;
            justify-content: flex-end;
            grid-column: 3;
        }

        /* --- CONTENT WRAPPER --- */
        .content-wrapper {
            max-width: 1400px;
            width: 95%;
            margin: 0 auto;
            margin-bottom: 50px;
            padding: 0;
        }



        /* Single-column mobile-first layout */
        .explorer-container {
            display: flex;
            flex-direction: column;
            gap: 24px;
            align-items: stretch;
        }

        .filters-column {
            display: flex;
            flex-direction: column;
            gap: 16px;
            order: 1;
        }

        .courses-column {
            display: flex;
            flex-direction: column;
            gap: 16px;
            order: 2;
        }

        .glass-section {
            background: var(--card-bg);
            border-radius: 20px;
            padding: 28px;
            border: 1px solid var(--border-color);
            box-shadow: 0 10px 30px var(--shadow);
            animation: fadeIn 0.8s ease;
            display: flex;
            flex-direction: column;
        }

        @media (max-width: 768px) {
            .glass-section {
                padding: 20px 20px 12px 20px;
                border-radius: 16px;
                position: sticky;
                top: 0;
                z-index: 100;
            }
        }

        /* --- SECTION HEADER --- */
        .explore-header { 
            margin-bottom: 20px;
            padding: 0 20px;
            transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
            opacity: 1;
            max-height: 200px;
            overflow: hidden;
        }

        .explore-header.hidden {
            display: none;
            opacity: 0;
            max-height: 0;
            margin-bottom: 0;
            pointer-events: none;
        }

        .explore-header h2 {
            background: linear-gradient(135deg, #1a73e8 0%, #00d4ff 100%);
            -webkit-background-clip: text;
            background-clip: text;
            color: transparent;
            margin: 0 0 12px 0;
            font-size: 2.5rem;
            font-weight: 800;
            letter-spacing: -0.5px;
            text-align: left;
        }

        .explore-header p {
            margin: 0;
            color: var(--text-muted);
            font-size: 0.9rem;
        }

        /* --- SECTION LABEL --- */
        .section-label {
            font-size: 0.8rem;
            color: var(--text-muted);
            margin: 0 0 12px 0;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 0.5px;
            display: flex;
            align-items: center;
            gap: 8px;
            order: 1;
            transition: all 0.3s ease;
        }

        #selectUniLabel { grid-row: 2;
            transition: opacity 0.3s ease, max-height 0.3s ease;
            max-height: 100px;
            opacity: 1;
        }

        #selectUniLabel.hidden {
            max-height: 0;
            opacity: 0;
            display: none;
        }

        /* --- BUTTON STYLES --- */
        .uni-btn,
        .campus-btn {
            border: none;
            background: var(--bg-color);
            color: var(--text-main);
            border-radius: 14px;
            cursor: pointer;
            font-weight: 600;
            font-family: var(--main-font);
            transition: all 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275);
        }

        /* University cards: Full-width with word wrapping */
        .uni-btn {
            width: 100%;
            padding: 16px 18px;
            font-size: 1rem;
            text-align: left;
            white-space: normal;
            word-wrap: break-word;
            word-break: break-word;
            line-height: 1.4;
            border: 1px solid var(--border-color);
            box-shadow: 0 2px 8px var(--shadow);
            transition: all 0.3s ease;
            display: block;
            margin-bottom: 12px; /* Added spacing between university cards */
        }

        .uni-btn:hover {
            transform: translateY(-2px);
            box-shadow: 0 4px 16px var(--shadow);
            border-color: var(--accent-blue);
        }

        .uni-btn.active {
            display: none !important;
            background: linear-gradient(135deg, #1a73e8, #00d4ff);
            color: white;
            border-color: transparent;
            box-shadow: 0 8px 20px rgba(26, 115, 232, 0.3);
        }

        .uni-btn.hidden {
            display: none;
        }

        /* Selected University Display */
        .selected-university-display { grid-row: 5; display: none !important; margin-bottom: 0 !important; animation: slideDown 0.3s cubic-bezier(0.4, 0, 0.2, 1);
            animation: slideDown 0.3s cubic-bezier(0.4, 0, 0.2, 1);
            visibility: hidden !important;
            height: 0 !important;
            overflow: hidden !important;
        }

        .selected-university-display.visible {
            display: none !important;
            visibility: hidden !important;
            height: 0 !important;
            overflow: hidden !important;
            max-height: 0 !important;
            margin: 0 !important;
            padding: 0 !important;
            border: none !important;
        }

        .selected-uni-card {
            display: none !important;
            visibility: hidden !important;
            height: 0 !important;
            width: 0 !important;
            overflow: hidden !important;
            background: linear-gradient(135deg, #1a73e8, #00d4ff);
            color: white;
            padding: 14px 16px;
            border-radius: 14px;
            font-weight: 600;
            white-space: normal;
            word-wrap: break-word;
            word-break: break-word;
            line-height: 1.4;
            box-shadow: 0 8px 20px rgba(26, 115, 232, 0.3);
            text-align: left;
        }

        /* Campus pills: Horizontal scroll, no wrap */
        .campus-btn {
            padding: 10px 16px;
            font-size: 0.9rem;
            white-space: nowrap;
            flex-shrink: 0;
            border: 1px solid var(--border-color);
            box-shadow: 0 2px 6px var(--shadow);
        }

        .campus-btn:hover {
            border-color: var(--accent-blue);
            transform: translateY(-2px);
            box-shadow: 0 4px 12px rgba(26, 115, 232, 0.15);
        }

        .campus-btn.active {
            background: linear-gradient(135deg, #1a73e8, #00d4ff);
            color: white;
            border-color: transparent;
            box-shadow: 0 8px 20px rgba(26, 115, 232, 0.3);
        }

        /* Change University button */
        .change-uni-btn { grid-row: 4; align-self: flex-start; padding: 8px 14px; font-size: 0.85rem; background: rgba(26, 115, 232, 0.1); color: var(--accent-blue); border: 1px solid var(--accent-blue); border-radius: 12px; cursor: pointer; font-weight: 600; font-family: var(--main-font); transition: all 0.3s ease; margin-bottom: 20px; margin-top: 10px; display: none;
            display: none;
        }

        .change-uni-btn.visible {
            display: inline-block;
        }

        .change-uni-btn.visible:hover {
            background: var(--accent-blue);
            color: white;
            transform: translateY(-1px);
        }

        /* Selected University Title */
        .selected-uni-title {
            display: none;
            margin-bottom: 20px;
            padding: 0 20px;
            animation: slideDown 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        }

        .selected-uni-title.visible {
            display: block !important;
        }

        .selected-uni-title h2 {
            margin: 0;
            font-size: 2.5rem;
            font-weight: 800;
            color: var(--text-main);
            word-break: break-word;
            line-height: 1.4;
            letter-spacing: -0.5px;
        }

        /* --- BUTTON CONTAINERS --- */
        .universities-buttons { grid-row: 3;
            transition: order 0.3s ease;
        }

        .campus-buttons {
            display: flex;
            gap: 10px;
            margin-bottom: 12px;
            align-items: center;
            animation: fadeIn 0.3s ease;
            order: 1;
            /* Horizontal scrolling */
            flex-wrap: nowrap;
            overflow-x: auto;
            overflow-y: hidden;
            scroll-behavior: smooth;
            -webkit-overflow-scrolling: touch;
            scrollbar-width: thin;
            padding: 8px 0 14px 0;
        }

        /* Subtle scrollbar styling */
        .campus-buttons::-webkit-scrollbar {
            height: 4px;
        }

        .campus-buttons::-webkit-scrollbar-track {
            background: transparent;
        }

        .campus-buttons::-webkit-scrollbar-thumb {
            background: var(--text-muted);
            border-radius: 2px;
            opacity: 0.3;
        }

        .campus-buttons::-webkit-scrollbar-thumb:hover {
            opacity: 0.6;
        }

        /* Mobile: Horizontal scrolling for campus buttons */
        @media (max-width: 768px) {
            .universities-buttons {
                gap: 12px;
            }

            .uni-btn {
                padding: 14px 16px;
                font-size: 0.95rem;
            }

            .campus-btn {
                padding: 10px 14px;
                font-size: 0.85rem;
            }
        }

        .unis-loading {
            font-size: 0.9rem;
            color: var(--text-muted);
        }

        /* --- CAMPUS SECTION --- */
        .campus-section { grid-row: 6; display: none; margin-top: 0; margin-bottom: 0; padding: 15px 0 0 0; opacity: 0;
            pointer-events: none;
            transition: opacity 0.3s ease;
            max-height: 0;
            overflow: visible !important;
        }

        .campus-section.active {
            display: block;
            animation: slideDown 0.4s cubic-bezier(0.4, 0, 0.2, 1);
            opacity: 1;
            pointer-events: auto;
            max-height: 500px;
        }

        /* Disabled/Grayed out state when no university is selected */
        .campus-section:not(.active) .section-label,
        .campus-section:not(.active) .campus-buttons {
            opacity: 0.5;
        }

        .campus-section:not(.active) .campus-btn {
            cursor: not-allowed;
            opacity: 0.6;
        }

        /* --- COURSE CARDS --- */
        .courses-section {
            margin-top: 20px;
            order: 2;
            transition: order 0.3s ease;
        }

        @media (max-width: 768px) {
            .courses-section {
                margin-top: 0;
            }
        }

        .courses-list {
            display: flex;
            flex-direction: column;
            gap: 12px;
        }

        .course-card {
            background: var(--bg-color);
            border: 1px solid var(--border-color);
            border-radius: 16px;
            padding: 18px;
            transition: all 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275);
        }

        .course-card:hover {
            transform: translateY(-4px);
            box-shadow: 0 8px 20px var(--shadow);
            border-color: var(--accent-blue);
        }

        .course-header {
            display: flex;
            justify-content: space-between;
            align-items: flex-start;
            gap: 12px;
            margin-bottom: 12px;
        }

        .course-name {
            margin: 0;
            font-size: 1.05rem;
            font-weight: 700;
            color: var(--text-main);
            flex: 1;
        }

        .riasec-badge {
            background: linear-gradient(135deg, #1a73e8, #00d4ff);
            color: white;
            padding: 4px 10px;
            border-radius: 16px;
            font-size: 0.7rem;
            font-weight: 700;
            white-space: nowrap;
        }

        .course-meta {
            font-size: 0.85rem;
            color: var(--text-muted);
            display: flex;
            flex-direction: column;
            gap: 4px;
        }

        .meta-item {
            display: flex;
            gap: 8px;
            align-items: baseline;
        }

        .meta-label {
            font-weight: 600;
            color: var(--text-main);
            min-width: 70px;
            font-size: 0.8rem;
        }

        /* --- EMPTY STATE --- */
        .empty-state {
            text-align: center;
            padding: 40px 20px;
            color: var(--text-muted);
        }

        .empty-state h3 {
            font-size: 1.1rem;
            margin: 0 0 8px 0;
            color: var(--text-main);
            font-weight: 700;
        }

        /* --- ANIMATIONS --- */
        @keyframes fadeIn {
            from {
                opacity: 0;
                transform: translateY(10px);
            }
            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        @keyframes spin {
            to {
                transform: rotate(360deg);
            }
        }

        @keyframes slideDown {
            from {
                opacity: 0;
                transform: translateY(-10px);
                max-height: 0;
            }
            to {
                opacity: 1;
                transform: translateY(0);
                max-height: 500px;
            }
        }

        /* --- RESPONSIVE --- */
        @media (max-width: 768px) {
            body { 
                padding-top: 80px;
                padding-bottom: 30px;
            }
            
            .navbar { height: 60px; }
            
            .nav-logo { font-size: 1.1rem; }
            
            .content-wrapper {
                margin-bottom: 30px;
            }
            
            .glass-section {
                padding: 18px;
                border-radius: 16px;
                margin-bottom: 0;
            }

            .uni-btn {
                padding: 14px 16px;
                font-size: 0.95rem;
            }

            .campus-btn {
                padding: 10px 14px;
                font-size: 0.85rem;
            }

            .course-header {
                flex-direction: column;
                align-items: flex-start;
            }

            .riasec-badge {
                align-self: flex-start;
            }

            .section-label {
                font-size: 0.75rem;
                margin: 8px 0 8px 0;
            }

            .course-name {
                font-size: 0.95rem;
            }
            
            .course-card {
                padding: 14px;
                border-radius: 12px;
            }
            
            .course-meta {
                font-size: 0.8rem;
            }
            
            .meta-label {
                min-width: 60px;
                font-size: 0.75rem;
            }
        }

        /* --- HOME ICON (DRAWER) --- */
        .nav-controls { display: flex; gap: 15px; align-items: center; }
        
        .home-icon {
            margin: 0;
            flex-shrink: 0;
        }

        /* --- MODALS --- */
        .modal-overlay {
            position: fixed;
            top: 0; left: 0; width: 100%; height: 100%;
            background: rgba(0, 0, 0, 0.149);
            backdrop-filter: blur(8px);
            -webkit-backdrop-filter: blur(8px);
            display: none;
            justify-content: center;
            align-items: center;
            z-index: 3000;
            animation: fadeIn 0.4s ease;
        }

        .modal-content {
            background: rgba(var(--nav-bg-rgb), 0.75) !important;
            backdrop-filter: blur(25px) saturate(150%);
            -webkit-backdrop-filter: blur(25px) saturate(150%);
            position: relative;
            width: 85%;
            max-width: 500px;
            margin: 100px auto 40px;
            padding: 40px;
            border-radius: 24px;
            z-index: 10001;
            border: 1px solid rgba(255, 255, 255, 0.12);
            box-shadow: 0 40px 100px rgba(0, 0, 0, 0.5), inset 0 0 0 1px rgba(255, 255, 255, 0.05);
            max-height: calc(100vh - 160px);
            overflow-y: auto;
        }

        .modal-close {
            position: absolute;
            top: 20px;
            right: 20px;
            width: 36px;
            height: 36px;
            background: #66666680;
            border-radius: 50%;
            border: 1px solid rgba(255, 255, 255, 0.1);
            cursor: pointer;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 0;
            transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
            z-index: 10;
        }

        .modal-close::before, .modal-close::after {
            content: '';
            position: absolute;
            width: 16px;
            height: 2px;
            background-color: var(--text-muted);
            border-radius: 2px;
            transition: background-color 0.3s ease;
        }

        .modal-close::before { transform: rotate(45deg); }
        .modal-close::after { transform: rotate(-45deg); }

        .modal-close:hover {
            background: hsla(0, 0%, 40%, 0.5);
            transform: rotate(135deg);
            border-color: rgba(255, 255, 255, 0.4);
        }

        .modal-close:hover::before, .modal-close:hover::after {
            background-color: #ffffff;
        }

        .light-mode .modal-close {
            background: rgba(0, 0, 0, 0.05);
            border-color: rgba(0, 0, 0, 0.1);
        }

        .light-mode .modal-close::before,
        .light-mode .modal-close::after {
            background-color: #333;
        }

        .modal-content h2 {
            font-size: 1.6rem;
            font-weight: 700;
            margin-bottom: 15px;
            color: var(--text-main);
        }

        .modal-content p {
            line-height: 1.6;
            color: var(--text-muted);
            margin-bottom: 15px;
        }

        .modal-content h3 {
            font-size: 1.1rem;
            margin-top: 20px;
            margin-bottom: 15px;
            color: var(--text-main);
        }

        .modal-content h4 {
            font-size: 0.95rem;
            margin-bottom: 10px;
            color: var(--accent-blue);
        }

        .modal-content ul {
            margin-left: 20px;
            color: var(--text-muted);
            line-height: 1.8;
        }

        .modal-content li {
            margin-bottom: 8px;
        }

        .research-goals {
            background: rgba(0, 0, 0, 0.2);
            padding: 15px;
            border-radius: 12px;
            margin: 15px 0;
        }

        .help-steps {
            display: flex;
            flex-direction: column;
            gap: 15px;
            margin: 15px 0;
        }

        .step {
            background: rgba(0, 0, 0, 0.2);
            padding: 15px;
            border-radius: 12px;
            line-height: 1.6;
            color: var(--text-muted);
        }

        .step strong {
            color: var(--accent-blue);
        }

        .researchers-list {
            list-style: none;
            padding: 0 !important;
            margin: 15px 0 !important;
            display: grid;
            grid-template-columns: repeat(2, 1fr);
            gap: 12px;
        }

        .researchers-list li {
            display: flex;
            align-items: center;
            gap: 10px;
            padding: 10px;
            background: rgba(0, 0, 0, 0.1);
            border-radius: 10px;
            font-size: 0.85rem;
            color: var(--text-muted);
        }

        .mini-avatar {
            width: 32px;
            height: 32px;
            border-radius: 50%;
            background: linear-gradient(135deg, var(--accent-blue), #00d4ff);
            flex-shrink: 0;
        }
    </style>
</head>
<body>

<div id="about-modal" class="modal-overlay">
    <div class="modal-content">
        <button class="modal-close" onclick="closeModal('about-modal')"></button>
        
       <h2>About T.A.H.A.K.</h2>
    <p><strong>T.A.H.A.K.</strong> is a web-based career assessment system designed specifically for Senior High School students in <strong>Nueva Ecija</strong>.</p>
    
    <p>Based on the <strong>RIASEC Model</strong> and the <strong>NCAE Occupational Interest Inventory</strong>, this tool helps bridge the gap between student interests and local academic opportunities. Our research focuses on reducing career undecidability caused by financial and geographic constraints.</p>
    
    <div class="research-goals">
        <h4>Research Objectives:</h4>
        <ul>
            <li>Evaluate system efficiency and interface concept.</li>
            <li>Compare web-based accessibility vs. traditional testing.</li>
            <li>Connect student profiles to local universities in Nueva Ecija.</li>
        </ul>
    </div>
    
    <p><small>Study Period: School Year 2025-2026</small></p>
        
        <h3>The Researchers</h3>
<ul class="researchers-list">
    <li>
        <div class="mini-avatar"></div>
        <span>Marcus Lord Isiah R. Basanes</span>
    </li>
    <li>
        <div class="mini-avatar"></div>
        <span>John Chester C. Canoza</span>
    </li>
    <li>
        <div class="mini-avatar"></div>
        <span>Jariz Maria T. Gose</span>
    </li>
    <li>
        <div class="mini-avatar"></div>
        <span>Rhiane Chastine Lei V. Perida</span>
    </li>
</ul>
    </div>
</div>

<div id="help-modal" class="modal-overlay">
    <div class="modal-content">
        <button class="modal-close" onclick="closeModal('help-modal')"></button>
        <h2>How to Take the Assessment</h2>
    <p>This assessment evaluates your <strong>Occupational Interests</strong>. There are no right or wrong answers.</p>
    
    <div class="help-steps">
        <div class="step">
            <strong>1. Be Honest:</strong> Select the level of enjoyment you feel for each activity, from "Strongly Dislike" to "Strongly Enjoy."
        </div>
        <div class="step">
            <strong>2. RIASEC Scoring:</strong> Your responses calculate your profile across six themes: Realistic, Investigative, Artistic, Social, Enterprising, and Conventional.
        </div>
        <div class="step">
            <strong>3. Local Results:</strong> Upon completion, you will receive your Top 3 Career categories and a list of universities in <strong>Nueva Ecija</strong> that offer related programs.
        </div>
    </div>
    
    <p><em>Your data is used solely for this research study on career decision-making.</em></p>
    </div>
</div>

<div class="mobile-drawer" id="drawer">
    <button class="close-drawer" id="close-drawer"></button>
    
    <div class="drawer-content">
        <h3>Menu</h3>
        <ul class="drawer-links">
            <li><a href="/" onclick="toggleDrawer()">Back to Test</a></li>
        </ul>
    </div>
</div>
<div class="drawer-overlay" id="overlay"></div>

<nav class="navbar">
    <div class="nav-container">
        <a href="/" class="nav-logo"><span>T.A.H.A.K.</span></a>
        <div class="nav-controls">
            <a href="/" class="home-icon" title="Back to Home">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="m3 9 9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"></path>
                    <polyline points="9 22 9 12 15 12 15 22"></polyline>
                </svg>
            </a>
        </div>
    </div>
</nav>

<div class="content-wrapper">
    
    <div class="explorer-container">
        <div class="filters-column">
            <div id="exploreHeader" class="explore-header">
                <h2>Explore Universities in Nueva Ecija</h2>
                <p>Find the courses and programs that match your career interests</p>
            </div>

            <div class="selected-uni-title" id="selectedUniTitle" style="display: none;">
                <h2 id="selectedUniNameDisplay"></h2>
            </div>

            <div class="section-label" id="selectUniLabel">
                <span></span> 
            </div>
            <div class="universities-buttons" id="universitiesContainer">
                <div class="unis-loading">Loading universities...</div>
            </div>

            <button class="change-uni-btn" id="changeUniBtn" onclick="deselectUniversity()">← Back to Universities</button>

            <div class="campus-section" id="campusSection">
                <div class="section-label">
                    Campuses:
                </div>
                <div class="campus-buttons" id="campusContainer"></div>
            </div>
        </div>


        <div class="courses-column">
            <div class="courses-section" id="coursesSection" style="display: none;">
                <div class="glass-section">
                    
                    <div class="courses-list" id="coursesList"></div>
                </div>
            </div>
        </div>
    </div>

</div>

    <script>
        let currentUni = '';
        let currentCampus = '';
        let searchQuery = '';
        let debounceTimer;
        let allCoursesCache = {}; // Cache for courses at each level

        console.log('explore.ejs script loaded');

        // Load theme from localStorage
        const savedTheme = localStorage.getItem('theme') || 'light';
        if (savedTheme === 'dark') document.body.classList.add('dark-mode');
        if (savedTheme === 'warm') document.body.classList.add('warm-mode');

        // LOAD UNIVERSITIES ON PAGE LOAD
        window.addEventListener('DOMContentLoaded', () => {
            console.log('DOMContentLoaded event fired');
            loadUniversities();
        });

        function loadUniversities() {
            console.log('loadUniversities called');
            fetch('/api/universities')
                .then(res => {
                    console.log('API response received:', res.status);
                    return res.json();
                })
                .then(universities => {
                    console.log('Universities data:', universities);
                    const html = universities.map(uni => `
                        <button class="uni-btn" onclick="selectUniversity('${escapeHtml(uni.name)}', event)" title="${escapeHtml(uni.name)}">
                            ${escapeHtml(uni.name)}
                        </button>
                    `).join('');
                    document.getElementById('universitiesContainer').innerHTML = html;
                    console.log('Universities rendered');
                })
                .catch(err => {
                    console.error('Error loading universities:', err);
                    document.getElementById('universitiesContainer').innerHTML = '<div class="unis-loading">Error loading universities</div>';
                });
        }

        function selectUniversity(uniName, event) {
            event.preventDefault();
            
            // If already selected, deselect
            if (currentUni === uniName) {
                deselectUniversity();
                return;
            }
            
            currentUni = uniName;
            currentCampus = '';
            searchQuery = '';

            // Hide header and show selected university display
            document.getElementById('exploreHeader').classList.add('hidden');
            document.getElementById('selectUniLabel').classList.add('hidden');
            document.getElementById('changeUniBtn').classList.add('visible');

            // Show selected university title
            document.getElementById('selectedUniNameDisplay').textContent = uniName;
            document.getElementById('selectedUniTitle').classList.add('visible');

            // Update button states - hide non-selected universities
            document.querySelectorAll('.uni-btn').forEach(btn => {
                const isSelected = btn.textContent.includes(uniName);
                btn.classList.toggle('active', isSelected);
                btn.classList.toggle('hidden', !isSelected);
            });

            // Load campuses
            fetch(`/api/universities/${encodeURIComponent(uniName)}/campuses`)
                .then(res => res.json())
                .then(campuses => {
                    const html = campuses.map(campus => `
                      <button class="campus-btn" onclick="selectCampus('${escapeHtml(uniName)}', '${escapeHtml(campus.name)}', event)" title="${escapeHtml(campus.name)}">
    ${escapeHtml(campus.name)}
</button>
                    `).join('');
                    if (campuses.length > 1) { document.getElementById('campusContainer').innerHTML = html;
                    document.getElementById('campusSection').classList.add('active'); } else if (campuses.length === 1) {
                        // Auto-select and load courses for single campus
                        currentCampus = campuses[0].name;
                        const campusName = campuses[0].name;
                        fetch(`/api/universities/${encodeURIComponent(uniName)}/campuses/${encodeURIComponent(campusName)}/courses`)
                            .then(res => res.json())
                            .then(courses => {
                                allCoursesCache[campusName] = courses;
                                displayCourses(courses);
                            })
                            .catch(err => console.error(err));
                        return;
                    }
                    
                    // Load all courses for this university by default
                    loadCoursesForUni(uniName);
                })
                .catch(err => console.error(err));
        }

        function deselectUniversity() {
            currentUni = '';
            currentCampus = '';
            searchQuery = '';

            // Show header again
            document.getElementById('exploreHeader').classList.remove('hidden');
            document.getElementById('selectUniLabel').classList.remove('hidden');
            document.getElementById('changeUniBtn').classList.remove('visible');
            document.getElementById('selectedUniTitle').classList.remove('visible');

            // Show all universities and remove active state
            document.querySelectorAll('.uni-btn').forEach(btn => {
                btn.classList.remove('active', 'hidden');
            });

            // Hide campus and courses sections
            document.getElementById('campusSection').classList.remove('active');
            document.getElementById('coursesSection').style.display = 'none';
        }

        function selectCampus(uniName, campusName, event) {
            event.preventDefault();
            
            // If already selected, deselect
            if (currentCampus === campusName) {
                deselectCampus(uniName);
                return;
            }
            
            currentCampus = campusName;
            searchQuery = '';

            // Update button states
            document.querySelectorAll('.campus-btn').forEach(btn => btn.classList.remove('active'));
            event.target.closest('.campus-btn').classList.add('active');

            // Load courses for this campus
            fetch(`/api/universities/${encodeURIComponent(uniName)}/campuses/${encodeURIComponent(campusName)}/courses`)
                .then(res => res.json())
                .then(courses => {
                    allCoursesCache[campusName] = courses;
                    displayCourses(courses);
                })
                .catch(err => console.error(err));
        }

        function deselectCampus(uniName) {
            currentCampus = '';
            searchQuery = '';

            // Remove active state from all campus buttons
            document.querySelectorAll('.campus-btn').forEach(btn => btn.classList.remove('active'));

            // Reload all courses for the university
            loadCoursesForUni(uniName);
        }

        function loadCoursesForUni(uniName) {
            // Load all campuses and aggregate their courses
            fetch(`/api/universities/${encodeURIComponent(uniName)}/campuses`)
                .then(res => res.json())
                .then(campuses => {
                    let allCourses = [];
                    let loaded = 0;
                    
                    campuses.forEach(campus => {
                        fetch(`/api/universities/${encodeURIComponent(uniName)}/campuses/${encodeURIComponent(campus.name)}/courses`)
                            .then(res => res.json())
                            .then(courses => {
                                allCoursesCache[campus.name] = courses;
                                allCourses = allCourses.concat(courses);
                                loaded++;
                                if (loaded === campuses.length) {
                                    // Deduplicate by course name
                                    const unique = {};
                                    allCourses.forEach(course => {
                                        if (!unique[course.courseName]) {
                                            unique[course.courseName] = course;
                                        }
                                    });
                                    displayCourses(Object.values(unique));
                                }
                            })
                            .catch(err => console.error(err));
                    });
                })
                .catch(err => console.error(err));
        }

        function displayCourses(courses) {
            if (courses.length === 0) {
                document.getElementById('coursesList').innerHTML = '<div class="empty-state"><h3>No courses found</h3></div>';
                document.getElementById('coursesSection').style.display = 'block';
                return;
            }

            const html = courses.map(course => `
                <div class="course-card">
                    <div class="course-header">
                        <h3 class="course-name">${escapeHtml(course.courseName || 'Course')}</h3>
                        <span class="riasec-badge">${escapeHtml(course.riasec)}</span>
                    </div>
                    <div class="course-meta">
                        ${course.major ? `<div class="meta-item"><span class="meta-label">Major:</span> <span>${escapeHtml(course.major)}</span></div>` : ''}
                        ${course.college ? `<div class="meta-item"><span class="meta-label">College:</span> <span>${escapeHtml(course.college)}</span></div>` : ''}
                    </div>
                </div>
            `).join('');

            document.getElementById('coursesList').innerHTML = html;
            document.getElementById('coursesSection').style.display = 'block';
        }

        function escapeHtml(text) {
            const map = { '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#039;' };
            return text.replace(/[&<>"']/g, m => map[m]);
        }

        // Drawer Toggle
        const closeBtn = document.getElementById('close-drawer');
        const drawer = document.getElementById('drawer');
        const overlay = document.getElementById('overlay');

        function toggleDrawer() {
            drawer.classList.toggle('active');
            overlay.classList.toggle('active');
        }

        closeBtn.addEventListener('click', toggleDrawer);
        overlay.addEventListener('click', toggleDrawer);

        // Modal functions
        function openModal(id) {
            const modal = document.getElementById(id);
            modal.style.display = 'flex';
            document.body.style.overflow = 'hidden';
        }

        function closeModal(id) {
            const modal = document.getElementById(id);
            modal.style.display = 'none';
            document.body.style.overflow = 'auto';
        }

        window.addEventListener('click', (event) => {
            if (event.target.classList.contains('modal-overlay')) {
                event.target.style.display = 'none';
                document.body.style.overflow = 'auto';
            }
        });

        function handleMenuClick(modalId) {
            toggleDrawer();
            openModal(modalId);
        }
    </script>
</body>
</html>
