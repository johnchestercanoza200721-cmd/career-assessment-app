<!DOCTYPE html>
<html>
<head>
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>T.A.H.A.K. | Results</title>
    
    <style>
        :root {
            --main-font: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
            --bg-color: #f0f2f5;
            --card-bg: #ffffff;
            --glass-bg: rgba(255, 255, 255, 0.7);
            --text-main: #2c3e50;
            --text-muted: #5f6368;
            --nav-bg-rgb: 255, 255, 255;
            --nav-text: #2c3e50;
            --border-color: #dadce0;
            --accent-blue: #1a73e8;
            --shadow: rgba(0,0,0,0.1);
            --bar-positive: #1a73e8;
            --bar-negative: #e67e22;
        }

        body.dark-mode {
            --bg-color: #121212;
            --card-bg: #1e1e1e;
            --glass-bg: rgba(30, 30, 30, 0.4);
            --text-main: #e8eaed;
            --text-muted: #9aa0a6;
            --nav-bg-rgb: 30, 30, 30;
            --nav-text: #e8eaed;
            --border-color: #3c4043;
        }

        body.warm-mode::after {
            content: ""; position: fixed; top: 0; left: 0; width: 100vw; height: 100vh;
            background: rgba(255, 145, 0, 0.12); pointer-events: none; z-index: 9999;
            mix-blend-mode: multiply;
        }

        html, body {
            margin: 0; padding: 0; width: 100%; overflow-x: hidden;
            font-family: var(--main-font); background-color: var(--bg-color);
            color: var(--text-main); -webkit-font-smoothing: antialiased;
        }

        body { padding-top: 90px; padding-bottom: 50px; }

        /* --- NAVBAR --- */
        .navbar {
            position: fixed;
            top: 0;
            left: 0;
            right: 0;
            width: 100%;
            height: 70px;
            
            background-color: rgba(var(--nav-bg-rgb), 0.25);
            backdrop-filter: blur(10px);
            -webkit-backdrop-filter: blur(10px);
            
            display: flex;
            justify-content: center;
            align-items: center;
            
            z-index: 2000;
            box-shadow: 0 2px 10px var(--shadow);
            border-bottom: 1px solid var(--border-color);
            
            transform: translateZ(0);
            -webkit-transform: translateZ(0);
            margin: 0;
            padding: 0;
        }

        .nav-container {
            display: grid;
            grid-template-columns: 1fr auto 1fr;
            align-items: center;
            width: 95%;
            max-width: 1200px;
            margin: 0 auto;
        }

        .nav-logo {
            font-size: 1.4rem;
            font-weight: 800;
            text-decoration: none;
            color: var(--nav-text);
            letter-spacing: -0.5px;
            transition: opacity 0.2s ease;
        }

        .nav-logo:hover { opacity: 0.8; }

        .nav-logo span {
            background: linear-gradient(135deg, #1a73e8, #00d4ff);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            font-weight: 900;
        }

        .hamburger {
            display: none !important;
        }

        /* --- MOBILE DRAWER --- */
        .mobile-drawer {
            display: none !important;
        }

        .mobile-drawer h3 {
            font-size: 2rem;
            font-weight: 800;
            color: var(--text-main);
            margin-bottom: 35px;
            padding-bottom: 15px;
            text-align: left;
            letter-spacing: -0.5px;
        }

        .mobile-drawer h3 span {
            color: var(--accent-blue);
        }

        .drawer-links {
            list-style: none !important;
            padding: 0 !important;
            margin: 0;
        }

        .drawer-links li {
            list-style: none !important;
            margin-bottom: 12px;
        }

        .drawer-links a {
            text-decoration: none;
            color: var(--text-main);
            font-size: 1rem;
            font-weight: 600;
            display: block;
            padding: 14px 20px;
            border-radius: 18px;
            
            background: hsla(0, 0%, 40%, 0.05);
            border: 1px solid hsla(0, 0%, 40%, 0.5);
            transition: all 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
        }

        .drawer-links a:hover {
            background: var(--accent-blue);
            color: white !important;
            transform: translateX(8px) scale(1.02);
            box-shadow: 0 8px 20px rgba(26, 115, 232, 0.3);
            border-color: rgba(255, 255, 255, 0.2);
        }

        .close-drawer {
            position: absolute;
            top: 20px;
            right: 20px;
            width: 36px;
            height: 36px;
            background: #66666680;
            border-radius: 50%;
            border: 1px solid rgba(255, 255, 255, 0.1);
            cursor: pointer;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 0;
            transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
            z-index: 10;
        }

        .close-drawer::before,
        .close-drawer::after {
            content: '';
            position: absolute;
            width: 16px;
            height: 2px;
            background-color: var(--text-muted);
            border-radius: 2px;
            transition: background-color 0.3s ease;
        }

        .close-drawer::before { transform: rotate(45deg); }
        .close-drawer::after { transform: rotate(-45deg); }

        .close-drawer:hover {
            background: rgba(255, 255, 255, 0.15);
            transform: rotate(135deg);
        }

        .close-drawer:hover::before,
        .close-drawer:hover::after {
            background-color: var(--text-main);
        }

        .light-mode .mobile-drawer {
            background: rgba(255, 255, 255, 0.95) !important;
            border: 1px solid rgba(0, 0, 0, 0.08);
            box-shadow: -10px 10px 40px rgba(0, 0, 0, 0.15);
        }

        .light-mode .mobile-drawer h3 {
            color: #000;
            border-bottom-color: rgba(0, 0, 0, 0.05);
        }

        .light-mode .drawer-links a {
            background: rgba(0, 0, 0, 0.05);
            border: 1px solid rgba(0, 0, 0, 0.05);
            color: #222;
        }

        .light-mode .drawer-links a:hover {
            background: var(--accent-blue);
            color: white !important;
        }

        .light-mode .close-drawer {
            background: rgba(0, 0, 0, 0.05);
            border-color: rgba(0, 0, 0, 0.1);
        }

        .drawer-overlay {
            display: none !important;
        }

        .drawer-overlay.active {
            display: none !important;
        }

        .drawer-content {
            position: relative;
        }

        .nav-controls {
            display: flex;
            gap: 15px;
            align-items: center;
            justify-content: flex-end;
            grid-column: 3;
        }

        /* --- SCREENSHOT BUTTON --- */
        .screenshot-btn {
            display: flex;
            align-items: center;
            gap: 8px;
            background: linear-gradient(135deg, #1a73e8, #00d4ff);
            color: white;
            border: none;
            padding: 10px 16px;
            border-radius: 20px;
            cursor: pointer;
            font-weight: 600;
            font-size: 0.9rem;
            transition: all 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275);
            font-family: var(--main-font);
        }

        .screenshot-btn:hover {
            transform: translateY(-2px);
            box-shadow: 0 8px 20px rgba(26, 115, 232, 0.3);
        }

        .screenshot-btn:active {
            transform: translateY(0);
        }

        @media (max-width: 600px) {
            .screenshot-btn {
                padding: 8px 12px;
                font-size: 0.8rem;
                gap: 6px;
            }
        }

        /* --- TOAST NOTIFICATION --- */
        .toast {
            position: fixed;
            bottom: 30px;
            left: 50%;
            transform: translateX(-50%) translateY(150px);
            background: rgba(0, 0, 0, 0.85);
            color: white;
            padding: 14px 24px;
            border-radius: 8px;
            font-size: 0.9rem;
            font-weight: 600;
            z-index: 5000;
            opacity: 0;
            transition: all 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275);
            pointer-events: none;
            box-shadow: 0 8px 25px rgba(0, 0, 0, 0.3);
        }

        .toast.show {
            transform: translateX(-50%) translateY(0);
            opacity: 1;
        }

        /* --- FLOATING LAYOUT --- */
        .content-wrapper {
            max-width: 800px;
            width: 95%;
            margin: 0 auto;
            display: flex;
            flex-direction: column;
            gap: 24px;
        }

        .glass-section {
            background: var(--card-bg);
            border-radius: 20px;
            padding: 28px;
            border: 1px solid var(--border-color);
            box-shadow: 0 10px 30px var(--shadow);
            animation: fadeIn 0.8s ease;
        }

        /* --- HOLLAND BADGE --- */
        .header-box { text-align: center; padding: 10px 0; }
        .holland-badge {
            display: inline-block;
            background: linear-gradient(135deg, #1a73e8 0%, #00d4ff 100%);
            color: white; padding: 12px 75px; border-radius: 100px;
            font-size: 2.2rem; font-weight: 800; letter-spacing: 5px;
            margin: 15px 0; border: 1px solid rgba(255, 255, 255, 0.2);
            box-shadow: 0 8px 20px rgba(26, 115, 232, 0.3), inset 0 1px 1px rgba(255, 255, 255, 0.3);
        }

        /* --- UNIFIED RANKED COURSE LIST --- */
        .unified-courses-container { display: grid; gap: 20px; }
        
        .course-card {
            background: var(--card-bg);
            border: 1px solid var(--border-color);
            border-radius: 16px;
            overflow: hidden;
            transition: all 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275);
            animation: slideUp 0.5s ease-out;
        }
        
        .course-card:hover {
            border-color: var(--accent-blue);
            box-shadow: 0 12px 30px var(--shadow);
            transform: translateY(-4px);
        }
        
        /* Top 3 Rank Highlights */
        .course-card-top-1,
        .course-card-top-2,
        .course-card-top-3 {
            background: linear-gradient(135deg, var(--card-bg), rgba(212, 165, 116, 0.03));
        }
        
        .course-card-top-1 { border-left-width: 6px; border-left-color: #d4a574; }
        .course-card-top-2 { border-left-width: 6px; border-left-color: #c0c0c0; }
        .course-card-top-3 { border-left-width: 6px; border-left-color: #cd7f32; }
        
        .course-card-header {
            display: flex;
            gap: 20px;
            padding: 20px;
            border-bottom: 1px solid var(--border-color);
            align-items: flex-start;
        }
        
        .course-rank-section {
            display: flex;
            align-items: center;
            flex-shrink: 0;
        }
        
        .course-rank-badge {
            display: flex;
            align-items: center;
            justify-content: center;
            width: 40px;
            height: 40px;
            border-radius: 50%;
            background: var(--bg-color);
            font-weight: 800;
            font-size: 1.3rem;
            color: var(--text-muted);
            border: 2px solid var(--border-color);
        }
        

        
        .course-info {
            flex-grow: 1;
            min-width: 0;
        }
        
        .course-title {
            margin: 0 0 6px 0;
            font-size: 1.15rem;
            font-weight: 700;
            color: var(--text-main);
            line-height: 1.3;
            word-break: break-word;
        }
        
        .course-category {
            font-size: 0.8rem;
            color: var(--accent-blue);
            font-weight: 500;
            opacity: 0.85;
        }
        
        .course-card-body {
            padding: 16px 20px;
        }
        
        /* --- INSTITUTIONS ACCORDION --- */
        .institutions-accordion {
            width: 100%;
        }
        
        .accordion-btn {
            width: 100%;
            padding: 14px 16px;
            border: 1px solid var(--border-color);
            border-radius: 10px;
            background: var(--bg-color);
            cursor: pointer;
            font-weight: 600;
            font-size: 0.9rem;
            display: flex;
            justify-content: space-between;
            align-items: center;
            color: var(--text-main);
            transition: all 0.2s ease;
        }
        
        .accordion-btn:hover {
            background: rgba(0, 0, 0, 0.03);
            border-color: var(--accent-blue);
        }
        
        .accordion-label { font-weight: 600; }
        
        .accordion-icon {
            opacity: 0.6;
            transition: transform 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275);
            display: inline-block;
        }
        
        .accordion-btn.expanded .accordion-icon {
            transform: rotate(180deg);
        }
        
        .accordion-content {
            max-height: 0;
            overflow: hidden;
            opacity: 0;
            transition: all 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275);
            margin-top: 0;
        }
        
        .accordion-content.expanded {
            max-height: 2000px;
            opacity: 1;
            margin-top: 12px;
        }
        
        .institutions-list {
            display: flex;
            flex-direction: column;
            gap: 12px;
        }
        
        .institution-item {
            padding: 12px;
            border-radius: 8px;
            background: var(--bg-color);
            transition: all 0.2s ease;
        }
        
        .institution-item.single-campus {
            padding: 14px;
            border-left: 3px solid var(--accent-blue);
        }
        
        .institution-item.multi-campus {
            border: 1px solid var(--border-color);
            padding: 0;
        }
        
        .institution-toggle {
            width: 100%;
            padding: 14px;
            display: flex;
            justify-content: space-between;
            align-items: center;
            border: none;
            background: transparent;
            cursor: pointer;
            font-weight: 600;
            font-size: 0.9rem;
            color: var(--text-main);
            transition: all 0.2s ease;
        }
        
        .institution-item.multi-campus .institution-toggle:hover {
            background: rgba(26, 115, 232, 0.05);
        }
        
        .institution-name {
            font-weight: 700;
            color: var(--text-main);
            flex-grow: 1;
            text-align: left;
        }
        
        .campus-count {
            font-size: 0.8rem;
            color: var(--text-muted);
            margin: 0 8px;
            font-weight: 500;
        }
        
        .toggle-icon {
            font-size: 0.8rem;
            color: var(--text-muted);
            transition: transform 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275);
            display: inline-block;
        }
        
        .institution-toggle.expanded .toggle-icon {
            transform: rotate(180deg);
        }
        
        .campuses-list {
            max-height: 0;
            overflow: hidden;
            opacity: 0;
            transition: all 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275);
        }
        
        .campuses-list.expanded {
            max-height: 1000px;
            opacity: 1;
        }
        
        .campus-item {
            padding: 12px 14px;
            border-top: 1px solid var(--border-color);
            font-size: 0.9rem;
            color: var(--text-main);
            padding-left: 28px;
            position: relative;
        }
        
        .campus-item::before {
            content: "├─";
            position: absolute;
            left: 14px;
            color: var(--text-muted);
            opacity: 0.5;
        }
        
        .major-info {
            font-size: 0.8rem;
            color: var(--accent-blue);
            margin-top: 4px;
            font-weight: 500;
        }

        /* --- SCORE CHART (POSITIVE SCORING) --- */
        .score-row { display: flex; align-items: center; margin-bottom: 18px; gap: 12px; }
        .trait-name { width: 110px; font-weight: 700; font-size: 0.7rem; text-align: right; text-transform: uppercase; color: var(--text-muted); letter-spacing: 0.3px; }
        .bar-wrapper { flex-grow: 1; height: 22px; background: rgba(0, 0, 0, 0.12); border-radius: 20px; position: relative; display: flex; align-items: center; overflow: hidden; box-shadow: inset 0 1px 3px rgba(0,0,0,0.15); }
        .bar-fill { height: 100%; transition: width 1.2s cubic-bezier(0.23, 1, 0.32, 1); display: flex; align-items: center; padding: 0 12px; font-size: 0.75rem; color: white; font-weight: 700; z-index: 4; white-space: nowrap; background: linear-gradient(90deg, var(--bar-positive), #00d4ff); border-radius: 20px; }

        /* --- RECOMMENDATION CARDS --- */
        .recommendation-group {
            background: var(--card-bg); padding: 28px; border-radius: 20px; 
            border: 1px solid var(--border-color); box-shadow: 0 10px 25px var(--shadow);
            transition: all 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275);
        }
        .recommendation-group:hover { transform: translateY(-4px); box-shadow: 0 15px 35px var(--shadow); border-color: var(--accent-blue); }
        .course-title { margin: 0 0 8px 0; color: var(--accent-blue); font-size: 1.15rem; font-weight: 700; line-height: 1.3; }
        
        /* Ensure screenshot doesn't include irrelevant elements */
        @media print {
            .navbar { display: none; }
            body { padding-top: 0; }
        }
        
        .provider-dropdown { margin-top: 18px; border: 1px solid var(--border-color); border-radius: 12px; background: var(--bg-color); overflow: hidden; transition: all 0.2s ease; }
        .provider-dropdown:hover { border-color: var(--accent-blue); }
        .provider-dropdown summary { padding: 14px 16px; cursor: pointer; font-weight: 600; font-size: 0.85rem; display: flex; justify-content: space-between; align-items: center; list-style: none; color: var(--text-main); }
        .provider-dropdown summary::after { content: ''; opacity: 0.6; transition: transform 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275); font-weight: 700; }
        .provider-dropdown[open] summary::after { transform: rotate(90deg); }
        .provider-list { padding: 0 16px 12px 16px; border-top: 1px solid var(--border-color); animation: slideDown 0.3s ease-out; }
        .provider-item { padding: 12px 0; border-bottom: 1px solid var(--border-color); font-size: 0.85rem; color: var(--text-main); }

        .btn {
            display: block; width: 100%; max-width: 320px; margin: 12px auto; 
            padding: 16px; background: linear-gradient(135deg, #1a73e8, #00d4ff);
            color: white; text-decoration: none; border-radius: 100px; font-weight: 700;
            text-align: center; box-shadow: 0 8px 20px rgba(26, 115, 232, 0.3);
            transition: all 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275);
        }

        .btn:hover {
            transform: translateY(-3px);
            box-shadow: 0 12px 28px rgba(26, 115, 232, 0.4);
        }

        .btn:active {
            transform: translateY(-1px);
        }

        .btn-ghost {
            background: transparent;
            color: var(--accent-blue);
            border: 2px solid var(--accent-blue);
            box-shadow: none;
        }

        .btn-ghost:hover {
            background: rgba(26, 115, 232, 0.1);
            box-shadow: 0 4px 12px rgba(26, 115, 232, 0.2);
        }

        #load-more-btn:hover {
            color: #666;
        }

        @keyframes fadeIn { from { opacity: 0; transform: translateY(20px); } to { opacity: 1; transform: translateY(0); } }
        @keyframes slideDown { from { opacity: 0; transform: translateY(-10px); } to { opacity: 1; transform: translateY(0); } @keyframes slideUp { from { opacity: 0; transform: translateY(20px); } to { opacity: 1; transform: translateY(0); } } }

        @media (max-width: 600px) {
            .holland-badge { font-size: 1.8rem; padding: 10px 40px; }
            .rank-badge { font-size: 1rem; }
            .trait-name { width: 85px; font-size: 0.7rem; }
            .course-title { font-size: 1.05rem; }
        }

        /* --- MODALS --- */
        .modal-overlay {
            position: fixed;
            top: 0; left: 0; width: 100%; height: 100%;
            background: rgba(0, 0, 0, 0.149);
            backdrop-filter: blur(8px);
            -webkit-backdrop-filter: blur(8px);
            display: none;
            justify-content: center;
            align-items: center;
            z-index: 3000;
            animation: fadeIn 0.4s ease;
        }

        .modal-content {
            background: rgba(var(--nav-bg-rgb), 0.75) !important;
            backdrop-filter: blur(25px) saturate(150%);
            -webkit-backdrop-filter: blur(25px) saturate(150%);
            position: relative;
            width: 85%;
            max-width: 500px;
            margin: 100px auto 40px;
            padding: 40px;
            border-radius: 24px;
            z-index: 10001;
            border: 1px solid rgba(255, 255, 255, 0.12);
            box-shadow: 0 40px 100px rgba(0, 0, 0, 0.5), inset 0 0 0 1px rgba(255, 255, 255, 0.05);
            max-height: calc(100vh - 160px);
            overflow-y: auto;
        }

        .modal-close {
            position: absolute;
            top: 20px;
            right: 20px;
            width: 36px;
            height: 36px;
            background: #66666680;
            border-radius: 50%;
            border: 1px solid rgba(255, 255, 255, 0.1);
            cursor: pointer;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 0;
            transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
            z-index: 10;
        }

        .modal-close::before, .modal-close::after {
            content: '';
            position: absolute;
            width: 16px;
            height: 2px;
            background-color: var(--text-muted);
            border-radius: 2px;
            transition: background-color 0.3s ease;
        }

        .modal-close::before { transform: rotate(45deg); }
        .modal-close::after { transform: rotate(-45deg); }

        .modal-close:hover {
            background: hsla(0, 0%, 40%, 0.5);
            transform: rotate(135deg);
            border-color: rgba(255, 255, 255, 0.4);
        }

        .modal-close:hover::before, .modal-close:hover::after {
            background-color: #ffffff;
        }

        .light-mode .modal-close {
            background: rgba(0, 0, 0, 0.05);
            border-color: rgba(0, 0, 0, 0.1);
        }

        .light-mode .modal-close::before,
        .light-mode .modal-close::after {
            background-color: #333;
        }

        .modal-content h2 {
            font-size: 1.6rem;
            font-weight: 700;
            margin-bottom: 15px;
            color: var(--text-main);
        }

        .modal-content p {
            line-height: 1.6;
            color: var(--text-muted);
            margin-bottom: 15px;
        }

        .modal-content h3 {
            font-size: 1.1rem;
            margin-top: 20px;
            margin-bottom: 15px;
            color: var(--text-main);
        }

        .modal-content h4 {
            font-size: 0.95rem;
            margin-bottom: 10px;
            color: var(--accent-blue);
        }

        .modal-content ul {
            margin-left: 20px;
            color: var(--text-muted);
            line-height: 1.8;
        }

        .modal-content li {
            margin-bottom: 8px;
        }

        .research-goals {
            background: rgba(0, 0, 0, 0.2);
            padding: 15px;
            border-radius: 12px;
            margin: 15px 0;
        }

        .help-steps {
            display: flex;
            flex-direction: column;
            gap: 15px;
            margin: 15px 0;
        }

        .step {
            background: rgba(0, 0, 0, 0.2);
            padding: 15px;
            border-radius: 12px;
            line-height: 1.6;
            color: var(--text-muted);
        }

        .step strong {
            color: var(--accent-blue);
        }

        .researchers-list {
            list-style: none;
            padding: 0 !important;
            margin: 15px 0 !important;
            display: grid;
            grid-template-columns: repeat(2, 1fr);
            gap: 12px;
        }

        .researchers-list li {
            display: flex;
            align-items: center;
            gap: 10px;
            padding: 10px;
            background: rgba(0, 0, 0, 0.1);
            border-radius: 10px;
            font-size: 0.85rem;
            color: var(--text-muted);
        }

        .mini-avatar {
            width: 32px;
            height: 32px;
            border-radius: 50%;
            background: linear-gradient(135deg, var(--accent-blue), #00d4ff);
            flex-shrink: 0;
        }
    </style>
</head>
<body>

<div id="about-modal" class="modal-overlay">
    <div class="modal-content">
        <button class="modal-close" onclick="closeModal('about-modal')"></button>
        
       <h2>About T.A.H.A.K.</h2>
    <p><strong>T.A.H.A.K.</strong> is a web-based career assessment system designed specifically for Senior High School students in <strong>Nueva Ecija</strong>.</p>
    
    <p>Based on the <strong>RIASEC Model</strong> and the <strong>NCAE Occupational Interest Inventory</strong>, this tool helps bridge the gap between student interests and local academic opportunities. Our research focuses on reducing career undecidability caused by financial and geographic constraints.</p>
    
    <div class="research-goals">
        <h4>Research Objectives:</h4>
        <ul>
            <li>Evaluate system efficiency and interface concept.</li>
            <li>Compare web-based accessibility vs. traditional testing.</li>
            <li>Connect student profiles to local universities in Nueva Ecija.</li>
        </ul>
    </div>
    
    <p><small>Study Period: School Year 2025-2026</small></p>
        
        <h3>The Researchers</h3>
<ul class="researchers-list">
    <li>
        <div class="mini-avatar"></div>
        <span>Marcus Lord Isiah R. Basanes</span>
    </li>
    <li>
        <div class="mini-avatar"></div>
        <span>John Chester C. Canoza</span>
    </li>
    <li>
        <div class="mini-avatar"></div>
        <span>Jariz Maria T. Gose</span>
    </li>
    <li>
        <div class="mini-avatar"></div>
        <span>Rhiane Chastine Lei V. Perida</span>
    </li>
</ul>
    </div>
</div>

<div id="help-modal" class="modal-overlay">
    <div class="modal-content">
        <button class="modal-close" onclick="closeModal('help-modal')"></button>
        <h2>How to Take the Assessment</h2>
    <p>This assessment evaluates your <strong>Occupational Interests</strong>. There are no right or wrong answers.</p>
    
    <div class="help-steps">
        <div class="step">
            <strong>1. Be Honest:</strong> Select the level of enjoyment you feel for each activity, from "Strongly Dislike" to "Strongly Enjoy."
        </div>
        <div class="step">
            <strong>2. RIASEC Scoring:</strong> Your responses calculate your profile across six themes: Realistic, Investigative, Artistic, Social, Enterprising, and Conventional.
        </div>
        <div class="step">
            <strong>3. Local Results:</strong> Upon completion, you will receive your Top 3 Career categories and a list of universities in <strong>Nueva Ecija</strong> that offer related programs.
        </div>
    </div>
    
    <p><em>Your data is used solely for this research study on career decision-making.</em></p>
    </div>
</div>

<div class="mobile-drawer" id="mobile-drawer">
    <button class="close-drawer" id="close-drawer"></button>
    
    <div class="drawer-content">
        <h3>Menu</h3>
        <ul class="drawer-links">
            <li><a href="/" onclick="toggleDrawer()">Back to Test</a></li>
        </ul>
    </div>
</div>
<div class="drawer-overlay" id="drawer-overlay"></div>

<nav class="navbar">
    <div class="nav-container">
        <a href="/" class="nav-logo"><span>T.A.H.A.K.</span></a>
        <div style="font-size: 0.8rem; opacity: 0.7; font-weight: bold; display: none;">COMPLETE</div>
        <div class="nav-controls">
            <button class="screenshot-btn" id="share-btn" title="Share your results">
                <span>SHARE</span>
            </button>
        </div>
    </div>
</nav>

<div class="content-wrapper">
    
    <div class="header-box">
        <h1 style="margin:0; font-size: 1.4rem;">Your Holland Code:</h1>
        <div class="holland-badge"><%= hollandCode %></div>
    </div>

    <div class="glass-section">
        <h3 style="margin: 0 0 20px 0; font-size: 0.9rem; text-align: center; color: var(--text-muted); text-transform: uppercase;">Interpretation</h3>
        <% 
            const hollandDescriptions = {
                'R': 'Realistic',
                'I': 'Investigative',
                'A': 'Artistic',
                'S': 'Social',
                'E': 'Enterprising',
                'C': 'Conventional'
            };
        %>
        <% hollandCode.split('').forEach(code => { %>
    <div style="margin-bottom: 18px;">
        <div style="margin-bottom: 10px;">
            <h4 style="margin: 0; font-size: 1.2rem; color: var(--text-main); font-weight: 700;"><%= hollandDescriptions[code] %></h4>
        </div>
        <p style="margin: 0; color: var(--text-muted); font-size: 0.9rem; line-height: 1.6;">
            <% if (code === 'R') { %>
                You're definitely someone who learns by doing. Psychologically, having a Realistic orientation just means you're hardwired to work with your hands, tools, or the physical world. Research on this type shows you find way more satisfaction in fixing a tangible problem than sitting through a theoretical lecture. You're practical, you value technical skill, and you're at your best when you can actually see the literal results of your hard work.
            <% } else if (code === 'I') { %>
                You're the type of person who needs to know how the world works. Vocational studies label this the Investigative type because you're driven by logic and a deep-seated curiosity. You'd rather spend hours solving a complex puzzle or analyzing data than leading a crowd or doing repetitive tasks. You're an independent thinker who trusts the scientific method, and you really thrive when you can dive into a research rabbit hole.
            <% } else if (code === 'A') { %>
                You have an Artistic personality, which in psychology means you're naturally drawn to things that are "unstructured." You probably hate following a rigid handbook and would much rather use your intuition to create something original. Research says you value aesthetics and independence way more than the average person. You aren't just being "rebellious"—you're actually at your most productive when you have the freedom to reimagine how things look and feel.
            <% } else if (code === 'S') { %>
                You have a Social profile, which is backed by a lot of research into empathy and emotional intelligence. Essentially, you're motivated by people, not machines or data. You're a natural at understanding what others need and helping them get there. Whether it's teaching or counseling, you find your biggest "wins" in the growth of the people around you. You're the glue in a collaborative team because you're wired to foster community and well-being.
            <% } else if (code === 'E') { %>
                You've got that Enterprising energy that vocational researchers link to leadership and ambition. You're a natural at persuading people and taking the lead on big projects. While some people shy away from the spotlight, you're comfortable taking risks and making the big calls to get a project across the finish line. You're less about the tiny technical details and more about the strategy it takes to turn a vision into a real success.
            <% } else if (code === 'C') { %>
                You're the Conventional type, which is actually the backbone of every successful system. Research shows you have a high aptitude for information processing—you see the patterns and details that everyone else misses. You find a genuine satisfaction in order, precision, and making sure things are done the right way. While others might thrive in chaos, you're the person who ensures the world actually stays on track and stays efficient.
            <% } %>
        </p>
    </div>
<% }) %>
    </div>

    <div class="glass-section">
        <h3 style="margin: 0 0 20px 0; font-size: 0.9rem; text-align: center; color: var(--text-muted); text-transform: uppercase;">Interest Intensity Profile</h3>
        <% 
            const traitNames = { R: "Realistic", I: "Investigative", A: "Artistic", S: "Social", E: "Enterprising", C: "Conventional" };
            Object.entries(scores).forEach(([key, score]) => { 
                let percentage = Math.min((score / 40) * 100, 100);
        %>
            <div class="score-row">
                <div class="trait-name"><%= traitNames[key] %></div>
                <div class="bar-wrapper">
                    <% if (score > 0) { %><div class="bar-fill" style="width: <%= percentage %>%;">+<%= score %></div><% } else { %><span style="position: absolute; left: 8px; font-size: 0.7rem; color: var(--text-muted); font-weight: 700;">0</span><% } %>
                </div>
            </div>
        <% }) %>
    </div>

    <!-- Unified Ranked Course List -->
    <div style="margin-top: 40px; margin-bottom: 0;">
        <h3 style="margin: 0 0 24px 0; font-size: 0.9rem; text-align: center; color: var(--text-muted); text-transform: uppercase;">Top Career &amp; Degree Paths</h3>
        
        <div class="unified-courses-container" id="courses-container">
            <% topMatches.forEach((group, courseIndex) => {
                const rank = courseIndex + 1;
                const isTopThree = rank <= 3;
                const rankColors = { 1: '#d4a574', 2: '#c0c0c0', 3: '#cd7f32' }; // Gold, Silver, Bronze
                const isHidden = courseIndex >= 10; // Hide courses beyond index 9 (top 10)
                
                // Group providers by university with campuses
                const groupedProviders = {};
                (group.providers || []).forEach(prov => {
                    if (!groupedProviders[prov.university]) {
                        groupedProviders[prov.university] = {
                            university: prov.university,
                            major: prov.major,
                            campuses: [],
                            firstCampus: prov.campus
                        };
                    }
                    if (prov.campus && !groupedProviders[prov.university].campuses.includes(prov.campus)) {
                        groupedProviders[prov.university].campuses.push(prov.campus);
                    }
                });
                
                const providerList = Object.values(groupedProviders);
                const hasCampusGroups = providerList.some(p => p.campuses.length > 1);
            %>
                <div class="course-card <%= isTopThree ? 'course-card-top-' + rank : '' %>" 
                     data-course-index="<%= courseIndex %>"
                     style="<%= isHidden ? 'display: none;' : '' %><%= isTopThree ? `border-left: 5px solid ${rankColors[rank]};` : '' %>"
                     >
                    
                    <div class="course-card-header">
                        <div class="course-rank-section">
                            <div class="course-rank-badge" <% if (isTopThree) { %>style="color: <%= rankColors[rank] %>; border-color: <%= rankColors[rank] %>;"<% } %>>
                                <%= rank %>
                            </div>
                        </div>
                        
                        <div class="course-info">
                            <h3 class="course-title"><%= group.courseName %></h3>
                            <% if (group.subcategoryName) { %>
                                <div class="course-category">
                                    Strongest match for <strong><%= group.subcategoryName %></strong>
                                </div>
                            <% } %>
                        </div>
                    </div>
                    
                    <div class="course-card-body">
                        <!-- Available Institutions Accordion -->
                        <div class="institutions-accordion">
                            <button class="accordion-btn <%= isTopThree ? 'expanded' : '' %>" 
                                    data-target="institutions-<%= courseIndex %>">
                                <span class="accordion-label">Available Institutions</span>
                                <span class="accordion-icon">▾</span>
                            </button>
                            
                            <div class="accordion-content <%= isTopThree ? 'expanded' : '' %>" 
                                 id="institutions-<%= courseIndex %>">
                                <div class="institutions-list">
                                    <% providerList.forEach((provider, idx) => {
                                        const hasCampuses = provider.campuses.length > 1;
                                    %>
                                        <% if (hasCampuses) { %>
                                            <!-- Multi-campus institution with sub-accordion -->
                                            <div class="institution-item multi-campus">
                                                <button class="institution-toggle" 
                                                        data-target="campuses-<%= courseIndex %>-<%= idx %>">
                                                    <span class="institution-name"><%= provider.university %></span>
                                                    <span class="campus-count">(<%= provider.campuses.length %> Campuses)</span>
                                                    <span class="toggle-icon">▾</span>
                                                </button>
                                                
                                                <div class="campuses-list" id="campuses-<%= courseIndex %>-<%= idx %>">
                                                    <% provider.campuses.forEach(campus => { %>
                                                        <div class="campus-item">
                                                            <%= campus %>
                                                            <% if (provider.major) { %>
                                                                <div class="major-info">Major in <%= provider.major %></div>
                                                            <% } %>
                                                        </div>
                                                    <% }) %>
                                                </div>
                                            </div>
                                        <% } else { %>
                                            <!-- Single-campus institution (no dropdown) -->
                                            <div class="institution-item single-campus">
                                                <div class="institution-name"><%= provider.university %></div>
                                                <% if (provider.major) { %>
                                                    <div class="major-info">Major in <%= provider.major %></div>
                                                <% } %>
                                            </div>
                                        <% } %>
                                    <% }) %>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            <% }) %>
        </div>
        
        <!-- Load More Text -->
        <div style="text-align: center; margin-top: 30px; margin-bottom: 20px;">
            <button id="load-more-btn" style="background: none; border: none; color: #999; font-size: 0.95rem; cursor: pointer; padding: 8px 0; transition: color 0.2s ease; font-weight: 700; font-family: var(--main-font);">
                Load More Courses
            </button>
        </div>
    </div>

    <a href="/explore" class="btn btn-ghost">Explore Courses</a>
    <a href="#" class="btn" id="retake-btn" onclick="resetAssessment(); return false;">Retake Assessment</a>
</div>

<script>
    // ========== SHARE RESULTS & PERSISTENCE FEATURE ==========
    
    let currentResults = {};

    /**
     * Save assessment result data to localStorage
     * @param {Object} resultData - The result object containing hollandCode, topPath, major, rank
     */
    function saveResultToLocalStorage(resultData) {
        localStorage.setItem('user_assessment_result', JSON.stringify(resultData));
    }

    /**
     * Load assessment result from localStorage
     * @returns {Object|null} The saved result object or null if not found
     */
    function loadResultFromLocalStorage() {
        const stored = localStorage.getItem('user_assessment_result');
        if (stored) {
            try {
                return JSON.parse(stored);
            } catch (e) {
                console.warn('Failed to parse stored result:', e);
                return null;
            }
        }
        return null;
    }

    /**
     * Generate a shareable URL with result parameters
     * @returns {string} The full shareable URL
     */
    function generateShareLink() {
        // Extract all 6 RIASEC scores from the rendered bars
        const scoreMap = { R: 0, I: 0, A: 0, S: 0, E: 0, C: 0 };
        const scoreBars = document.querySelectorAll('.score-row');
        const traitOrder = ['R', 'I', 'A', 'S', 'E', 'C'];
        
        scoreBars.forEach((row, index) => {
            if (index < traitOrder.length) {
                const barFill = row.querySelector('.bar-fill');
                if (barFill && barFill.textContent) {
                    const scoreText = barFill.textContent.trim();
                    const score = parseInt(scoreText.replace('+', '')) || 0;
                    scoreMap[traitOrder[index]] = score;
                }
            }
        });
        
        // Build URL with all parameters
        const params = new URLSearchParams();
        params.append('r', scoreMap.R);
        params.append('i', scoreMap.I);
        params.append('a', scoreMap.A);
        params.append('s', scoreMap.S);
        params.append('e', scoreMap.E);
        params.append('c', scoreMap.C);
        params.append('code', currentResults.hollandCode || '');
        params.append('path', encodeURIComponent(currentResults.topPath || ''));
        params.append('major', encodeURIComponent(currentResults.major || ''));
        params.append('rank', currentResults.rank || '1');
        
        // Point to root with query parameters
        const shareUrl = `${window.location.origin}/?${params.toString()}`;
        return shareUrl;
    }

    /**
     * Copy text to clipboard with fallback support
     * @param {string} text - The text to copy
     * @returns {Promise<boolean>} True if successful
     */
    function copyToClipboard(text) {
        if (navigator.clipboard && window.isSecureContext) {
            return navigator.clipboard.writeText(text)
                .then(() => true)
                .catch(() => legacyCopyToClipboard(text));
        } else {
            return Promise.resolve(legacyCopyToClipboard(text));
        }
    }

    /**
     * Legacy clipboard copy fallback
     * @param {string} text - The text to copy
     * @returns {boolean} True if successful
     */
    function legacyCopyToClipboard(text) {
        const textarea = document.createElement('textarea');
        textarea.value = text;
        textarea.style.position = 'fixed';
        textarea.style.opacity = '0';
        document.body.appendChild(textarea);
        
        try {
            textarea.select();
            const success = document.execCommand('copy');
            document.body.removeChild(textarea);
            return success;
        } catch (err) {
            document.body.removeChild(textarea);
            return false;
        }
    }

    /**
     * Show a toast notification
     * @param {string} message - The message to display
     * @param {number} duration - Duration in milliseconds (default: 3000)
     */
    function showToast(message, duration = 3000) {
        let toast = document.getElementById('share-toast');
        if (!toast) {
            toast = document.createElement('div');
            toast.id = 'share-toast';
            toast.className = 'toast';
            document.body.appendChild(toast);
        }
        
        toast.textContent = message;
        toast.classList.add('show');
        
        setTimeout(() => {
            toast.classList.remove('show');
        }, duration);
    }

    /**
     * Handle share button click with Web Share API
     */
    function handleShareClick() {
        const shareUrl = generateShareLink();
        
        if (navigator.share) {
            navigator.share({
                title: 'My T.A.H.A.K. Results',
                text: `Check out my career assessment results! Holland Code: ${currentResults.hollandCode}`,
                url: shareUrl
            }).catch(err => {
                if (err.name !== 'AbortError') {
                    handleShareFallback(shareUrl);
                }
            });
        } else {
            handleShareFallback(shareUrl);
        }
    }

    /**
     * Fallback share method: copy URL and show toast
     * @param {string} shareUrl - The URL to copy
     */
    function handleShareFallback(shareUrl) {
        copyToClipboard(shareUrl).then(success => {
            if (success) {
                showToast('Result link copied to clipboard! 📋');
            } else {
                showToast('Failed to copy link. Please try again.');
            }
        });
    }

    /**
     * Reset assessment and return to test
     */
    function resetAssessment() {
        localStorage.removeItem('user_assessment_result');
        window.location.href = '/';
    }

    /**
     * Initialize: extract current results from page and save to localStorage
     */
    function initializeResults() {
        // Extract Holland Code from badge
        const hollandBadge = document.querySelector('.holland-badge');
        if (hollandBadge && hollandBadge.textContent) {
            currentResults.hollandCode = hollandBadge.textContent.trim();
        }
        
        // Extract top path from first course card
        const firstCourseTitle = document.querySelector('.course-title');
        if (firstCourseTitle && firstCourseTitle.textContent) {
            currentResults.topPath = firstCourseTitle.textContent.trim();
        }
        
        // Extract all 6 RIASEC scores from the rendered Interest Intensity Profile
        const scoreMap = { R: 0, I: 0, A: 0, S: 0, E: 0, C: 0 };
        const scoreBars = document.querySelectorAll('.score-row');
        const traitOrder = ['R', 'I', 'A', 'S', 'E', 'C'];
        
        scoreBars.forEach((row, index) => {
            if (index < traitOrder.length) {
                const barFill = row.querySelector('.bar-fill');
                if (barFill && barFill.textContent) {
                    const scoreText = barFill.textContent.trim();
                    const score = parseInt(scoreText.replace('+', '')) || 0;
                    scoreMap[traitOrder[index]] = score;
                }
            }
        });
        
        // Store scores in currentResults
        currentResults.scores = scoreMap;
        
        // Set default rank
        currentResults.rank = 1;
        
        // If we have at least the Holland code, save to localStorage
        if (currentResults.hollandCode && currentResults.topPath) {
            saveResultToLocalStorage(currentResults);
        }
    }

    // ========== PAGE INITIALIZATION ==========
    
    // Initialize Pagination for Load More
    let currentlyShown = 10; // Start by showing first 10 courses
    const loadMoreBtn = document.getElementById('load-more-btn');
    const coursesContainer = document.getElementById('courses-container');
    const allCourses = coursesContainer ? Array.from(coursesContainer.querySelectorAll('.course-card')) : [];
    const totalCourses = allCourses.length;

    function updateLoadMoreButton() {
        if (currentlyShown >= totalCourses) {
            // Hide button when all courses are shown
            if (loadMoreBtn) {
                loadMoreBtn.style.display = 'none';
            }
        } else {
            // Show button if there are more courses
            if (loadMoreBtn) {
                loadMoreBtn.style.display = 'inline-flex';
            }
        }
    }

    function loadMoreCourses() {
        const nextCount = Math.min(currentlyShown + 10, totalCourses);
        
        for (let i = currentlyShown; i < nextCount; i++) {
            if (allCourses[i]) {
                allCourses[i].style.display = '';
            }
        }
        
        currentlyShown = nextCount;
        updateLoadMoreButton();

        // Smooth scroll to the newly loaded courses
        if (allCourses[currentlyShown - 10]) {
            allCourses[currentlyShown - 10].scrollIntoView({ behavior: 'smooth', block: 'start' });
        }
    }

    if (loadMoreBtn) {
        loadMoreBtn.addEventListener('click', function(e) {
            e.preventDefault();
            loadMoreCourses();
        });
        updateLoadMoreButton();
    }

    // Initialize Unified Course List Accordions
    document.addEventListener('DOMContentLoaded', function() {
        // Handle main accordion buttons for each course card
        const accordionBtns = document.querySelectorAll('.accordion-btn');
        accordionBtns.forEach(btn => {
            btn.addEventListener('click', function(e) {
                e.preventDefault();
                const targetId = this.getAttribute('data-target');
                const content = document.getElementById(targetId);
                
                if (!content) return;
                
                const isExpanded = this.classList.contains('expanded');
                
                // Toggle expanded state
                this.classList.toggle('expanded');
                content.classList.toggle('expanded');
            });
        });
        
        // Handle institution toggle buttons for multi-campus institutions
        const institutionToggles = document.querySelectorAll('.institution-toggle');
        institutionToggles.forEach(toggle => {
            toggle.addEventListener('click', function(e) {
                e.preventDefault();
                const targetId = this.getAttribute('data-target');
                const campusList = document.getElementById(targetId);
                
                if (!campusList) return;
                
                const isExpanded = this.classList.contains('expanded');
                
                // Toggle expanded state
                this.classList.toggle('expanded');
                campusList.classList.toggle('expanded');
            });
        });
    });

    // Initialize results (extract from page and save to localStorage)
    initializeResults();

    // Apply theme preferences
    if (localStorage.getItem('theme') === 'dark') document.body.classList.add('dark-mode');
    if (localStorage.getItem('warm') === 'true') document.body.classList.add('warm-mode');

    // Share Results button functionality
    const shareBtn = document.getElementById('share-btn');
    shareBtn.addEventListener('click', () => {
        const btn = shareBtn;
        const originalText = btn.innerHTML;
        btn.innerHTML = '<span>Generating...</span>';
        btn.disabled = true;

        setTimeout(() => {
            handleShareClick();
            
            btn.innerHTML = '<span>Shared!</span>';
            setTimeout(() => {
                btn.innerHTML = originalText;
                btn.disabled = false;
            }, 2000);
        }, 300);
    });

    // Modal functions
    function openModal(id) {
        const modal = document.getElementById(id);
        modal.style.display = 'flex';
        document.body.style.overflow = 'hidden';
    }

    function closeModal(id) {
        const modal = document.getElementById(id);
        modal.style.display = 'none';
        document.body.style.overflow = 'auto';
    }

    window.addEventListener('click', (event) => {
        if (event.target.classList.contains('modal-overlay')) {
            event.target.style.display = 'none';
            document.body.style.overflow = 'auto';
        }
    });
</script>
</body>
</html>
